{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SUPABASE_CONNECTION_STRING"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "BookReviewsApi",
    "Audience": "BookReviewsApp"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  }
}
